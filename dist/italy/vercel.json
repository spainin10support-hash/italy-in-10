{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "sarah/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/legal",
      "dest": "/legal/index.html"
    },
    {
      "src": "/phrases",
      "dest": "/phrases/index.html"
    },
    {
      "src": "/fiestas/(.*)",
      "dest": "/fiestas/$1"
    },
    {
      "src": "/help",
      "dest": "/help/index.html"
    },
    {
      "src": "/city/(.*)",
      "dest": "/city/$1"
    },
    {
      "src": "/journey/(.*)",
      "dest": "/journey/$1"
    },
    {
      "src": "/sarah/(.*)",
      "dest": "/sarah/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    }
  ]
}